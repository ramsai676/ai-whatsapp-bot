# Copy to ".env". The bot runs fully via the built-in SIMULATOR with none of
# these set. Add them to enable real WhatsApp and AI free-form answers.

# --- Optional: Gemini for free-form questions the rules don't match ---
# Free API key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Optional: Meta WhatsApp Cloud API (to go live) ---
# From your Meta App -> WhatsApp -> API setup.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# You choose this string; enter the same value in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=dev-verify-token

PORT=3005
